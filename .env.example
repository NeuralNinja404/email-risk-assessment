# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=emailrisk
POSTGRES_USER=emailrisk
POSTGRES_PASSWORD=emailrisk_secret

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Ingest Service ──
API_KEY=changeme-generate-a-real-key
ATTACHMENT_STORAGE_PATH=/data/attachments
MAX_FILE_SIZE_MB=50
INGEST_RATE_LIMIT=10/second

# ── Scoring Weights ──
WEIGHT_SIGNATURE=0.20
WEIGHT_BEHAVIORAL=0.40
WEIGHT_REPUTATION=0.25
WEIGHT_CONTEXT=0.15

# ── Policy Thresholds ──
THRESHOLD_LOW=0.30
THRESHOLD_HIGH=0.70
GRAY_ZONE_MARGIN=0.03

# ── External APIs ──
VIRUSTOTAL_API_KEY=
ALIENVAULT_OTX_API_KEY=
MISP_URL=
MISP_API_KEY=

# ── Sandbox (CAPE) ──
CAPE_API_URL=
CAPE_TIMEOUT_QUICK=120
CAPE_TIMEOUT_EXTENDED=300

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json
